# === LLM Keys (use at least one) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === GitHub ===
GITHUB_TOKEN=ghp_...           # classic token with repo:read scope
GITHUB_TARGET_REPO=owner/repo  # e.g. vercel/next.js

# === Vector Store ===
CHROMA_PERSIST_DIR=./chroma_db

# === App Config ===
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000

# === Embedding Model ===
EMBEDDING_MODEL=text-embedding-3-small   # cheapest, still excellent
LLM_MODEL=gpt-4o-mini                    # swap to claude-3-5-sonnet if preferred
